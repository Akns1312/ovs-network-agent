# Ollama Configuration - Local LLM running on your desktop
#
# Ensure Ollama is running: ollama serve
# And the model is pulled: ollama pull mistral

# Ollama base URL (default localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (ensure this model is pulled in Ollama)
# Popular models: mistral, llama2, neural-chat, orca-mini, dolphin-mixtral
OLLAMA_MODEL=mistral

# Optional: Ollama API key (if your Ollama instance requires authentication)
# OLLAMA_API_KEY=your_api_key_here